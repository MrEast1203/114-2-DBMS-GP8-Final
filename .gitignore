# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Python (uv)
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
*.egg-info/
# uv lockfile is committed (per uv recommendation); only env is ignored

# Data (large, regenerable from OpenAlex)
data/
logs/
*.jsonl
*.sql.gz

# HTML report artifacts kept for the author's own viewing — not published
*.html

# Exception: eval/ holds version-controlled ground truth + query specs
!eval/*.jsonl

# Working files (regenerated by build_candidate_pool.py / apply_labels_50k.py)
eval/labeling_worksheet.txt
eval/labeling_titles.txt

# Env + secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
*.swp
.idea/
.vscode/

# Local tooling (machine-specific)
.claude/
.mcp.json

# Docker volumes
postgres-data/
eval/candidates_*.jsonl.bak
